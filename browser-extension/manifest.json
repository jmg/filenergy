{
  "manifest_version": 3,
  "name": "Filenergy: Save Page",
  "description": "Send the current tab to your Filenergy workspace.",
  "version": "0.1.0",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Filenergy"
  },
  "icons": {}
}
